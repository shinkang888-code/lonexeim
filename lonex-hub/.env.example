# Lonex Hub — Vercel + Neon
DATABASE_URL=postgresql://user:pass@host/neondb?sslmode=require

# 본사 HQ (서버 전용 — NEXT_PUBLIC_ 금지)
LONEX_HQ_ADMIN_SECRET=change-me-in-production
LONEX_HQ_KEY_PEPPER=change-me-pepper

# Hugging Face Inference API (AI chat/embed/PII)
HF_TOKEN=

# Kaggle API (datasets, borderless STT 파인튜닝 참고)
KAGGLE_API_TOKEN=

# OSS 모듈 URL (Docker compose 또는 SaaS)
# 로컬 Docker: .\scripts\docker-oss.ps1 up -Profile all -Wait -SyncEnv
# Vercel 프로덕션 + 로컬 Docker: .\scripts\docker-vercel.ps1
# (cloudflared HTTPS tunnel → vercel env add → deploy --prod)
NEXT_PUBLIC_DIFY_URL=http://localhost:3001
NEXT_PUBLIC_ROCKETCHAT_URL=http://localhost:3002
NEXT_PUBLIC_ROUNDCUBE_URL=http://localhost:8080
NEXT_PUBLIC_CALCOM_URL=http://localhost:3005
NEXT_PUBLIC_AKAUNTING_URL=http://localhost:8082
NEXT_PUBLIC_LIVEKIT_MEET_URL=https://meet.livekit.io/custom?liveKitUrl=ws://localhost:7880
NEXT_PUBLIC_MEDIACMS_URL=http://localhost:8800
NEXT_PUBLIC_LIVEKIT_URL=http://localhost:7880
NEXT_PUBLIC_NEXTCLOUD_URL=http://localhost:8081
NEXT_PUBLIC_OUTLINE_URL=http://localhost:3003
NEXT_PUBLIC_CHATWOOT_URL=http://localhost:3004
NEXT_PUBLIC_LOGSHIELD_CONSOLE_URL=https://logshield-phi.vercel.app

# Figma (scripts/figma-sync.mjs — 커밋 금지, scripts/figma.env 사용)
# FIGMA_ACCESS_TOKEN=
# FIGMA_TEAM_ID=
# FIGMA_FILE_KEY=
